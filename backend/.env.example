# Copiar este archivo a .env y ajustar los valores
# NUNCA commitear el archivo .env con credenciales reales

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=proyecto_go
DB_SSLMODE=disable

# Servidor HTTP
SERVER_PORT=8080

# JWT — genera un secreto seguro con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres
